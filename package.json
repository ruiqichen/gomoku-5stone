{
  "name": "gomoku-5stone",
  "version": "1.0.0",
  "description": "跨平台五子棋游戏",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:linux": "electron-builder --linux AppImage",
    "build:win": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg"
  },
  "author": "ruiqichen",
  "license": "ISC",
  "build": {
    "appId": "com.ruiqichen.gomoku",
    "productName": "五子棋",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}
